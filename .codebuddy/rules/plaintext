com.example.app
├── common/             # 通用工具、扩展函数、基类
├── data/               # 数据层
│   ├── remote/         # API 接口、DTO
│   ├── local/          # Room 数据库、Entity、DAO
│   └── repository/     # Repository 实现类
├── domain/             # 领域层
│   ├── model/          # 业务模型
│   ├── repository/     # Repository 接口
│   └── usecase/        # 业务逻辑单元
├── di/                 # Hilt 依赖注入配置
└── ui/                 # 展示层 (按功能模块划分)
    ├── feature_name/
    │   ├── components/ # 该模块专用的小组件
    │   ├── HomeContract.kt # 定义 State, Event, Effect
    │   ├── HomeViewModel.kt
    │   └── HomeScreen.kt
    └── theme/          # 设计系统 (Color, Type, Shape)